# atlas-photos pipeline — GPU worker image
# Handles: embed (Qwen3-VL-Embedding-2B), faces (InsightFace buffalo_l), caption (vLLM Qwen2.5-VL-3B-AWQ)
#
# Base image ships torch + vllm + CUDA runtime — do NOT pip-install torch/vllm on top.
# NOTE: pipeline source is NOT baked into this image. docker-compose mounts
# the pipeline directory at /app; entrypoint_gpu.sh lives there too.
# Rebuild only when dependencies change.

FROM vllm/vllm-openai@sha256:e4f88a835143cd22aee2397a26ec6bb80b3a4a6fe0c882bcbc63822904766089

# - build-essential: insightface ships as sdist with Cython extensions
# - libgl1/libglib2.0-0: runtime deps of opencv-python (pulled in by insightface)
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        libgl1 \
        libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

RUN python3 -m pip install --no-cache-dir \
        insightface \
        onnxruntime-gpu \
        "psycopg[binary]" \
        pillow \
        pillow-heif

# Qwen3-VL-Embedding-2B (embed stage + embed-api sidecar): the model repo's
# scripts/qwen3_vl_embedding.py helper needs qwen-vl-utils for its chat-template
# preprocessing; `av` (PyAV) is the FFmpeg-backed decoder qwen-vl-utils uses to
# pull the 12 evenly-spaced frames out of each video. torchcodec/torchvision/
# transformers are already in the vllm base image. Pinned to the versions the
# migration was validated against.
RUN python3 -m pip install --no-cache-dir \
        "qwen-vl-utils==0.0.14" \
        "av==18.0.0"

# insightface depends on plain `onnxruntime` (CPU); pip installs BOTH, and the
# CPU wheel shadows the GPU one (same module name) — the CUDA EP then simply
# doesn't exist ('available: Azure, CPU'). Purge the CPU wheel, force-reinstall
# the GPU wheel, and provide the cu12 runtime libs its CUDA EP links against
# (the base image is cu13; entrypoint_gpu.sh puts nvidia/*/lib on the loader
# path). Verified need: cudnn9 + cublas + cufft + curand.
RUN python3 -m pip uninstall -y onnxruntime \
    && python3 -m pip install --no-cache-dir --force-reinstall onnxruntime-gpu \
    && python3 -m pip install --no-cache-dir \
        "nvidia-cudnn-cu12" "nvidia-cublas-cu12" "nvidia-cufft-cu12" "nvidia-curand-cu12" \
    && python3 -c "import onnxruntime as o; ps=o.get_available_providers(); \
        assert 'CUDAExecutionProvider' in ps, ps; print('ORT providers OK:', ps)"

WORKDIR /app

# The vllm/vllm-openai image's own entrypoint launches the OpenAI API server —
# it MUST be overridden. Our entrypoint downloads models (idempotent), then
# exec's the GPU worker loop. Invoked via bash so a lost exec bit on the
# host-mounted script can never break startup.
ENTRYPOINT ["/bin/bash", "/app/entrypoint_gpu.sh"]
