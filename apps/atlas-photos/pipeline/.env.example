# atlas-pipeline host-side configuration.
# Copy to .env (gitignored) next to docker-compose.yml and adjust — docker
# compose reads it automatically for ${...} interpolation.

# Host directory of the photo library (contains originals/, thumbs/, faces/)
ATLAS_PHOTOS_DIR=/srv/atlas/photos

# Host directory for model caches (~6 GB Hugging Face + insightface downloads)
ATLAS_MODELS_DIR=/srv/atlas/models

# File containing POSTGRES_PASSWORD=... — mounted read-only at /secrets/.env.
# Default is the backend compose secrets file, relative to this directory.
ATLAS_PG_ENV_FILE=../../../backend/docker/.env

# uid:gid that owns the photo library on the host (pipeline-cpu writes thumbs
# as this user so host tools can touch them)
ATLAS_PIPELINE_UID=1000
ATLAS_PIPELINE_GID=1000

# Git revision of Qwen/Qwen3-VL-Embedding-2B to download and run. Code shipped
# inside that repo (scripts/qwen3_vl_embedding.py) is IMPORTED AND EXECUTED by
# the workers — pin a commit sha here to freeze the supply chain.
ATLAS_EMBED_REVISION=main
